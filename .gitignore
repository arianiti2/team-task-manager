# Delete the empty .gitignore
Remove-Item .gitignore

# Create a proper .gitignore with all necessary exclusions
@"
# Dependencies
node_modules/
package-lock.json

# Environment
.env
.env.local
.env.production

# Logs
*.log
logs/
combined.log
error.log

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# Testing
coverage/
.nyc_output/

# Runtime
tmp/
temp/
dist/
build/

# Debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# System Files
*.class
*.exe
*.dll
*.so
*.dylib
"@ | Out-File -FilePath .gitignore -Encoding utf8

# Verify the file was created
Get-Content .gitignore